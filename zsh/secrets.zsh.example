# Secret Environment Variables Template
# Copy this file to secrets.zsh and fill in real tokens
# secrets.zsh is in .gitignore and won't be committed to git

# Figma
export COPILOT_MCP_FIGMA_API_TOKEN="your_figma_token_here"

# Snyk
export SNYK_TOKEN="your_snyk_token_here"

# FedRAMP SAR
export FEDRAMP_SAR_CREDENTIAL_BASE64="your_credential_here"

# SonarQube
export SONARQUBE_TOKEN="your_sonarqube_token_here"

# GitHub Tokens
export GITHUB_TOKEN="your_bundle_github_token_here"
export HOMEBREW_GITHUB_API_TOKEN="your_homebrew_github_token_here"

# Jira / Confluence
export JIRA_API_TOKEN="your_jira_api_token_here"

# AnythingLLM
export ANYTHINGLLM_API_KEY="your_anythingllm_api_key_here"

# Dialogflow Credentials
export COM_TD_WFM_DIALOGFLOW_CREDENTIALS="your_dialogflow_credentials_here"
