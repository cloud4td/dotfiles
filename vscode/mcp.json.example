{
  "servers": {
    "td-docs": {
      "type": "stdio",
      "command": "node",
      "args": ["/Users/cloud/work/talkdesk/code/confucius/mcp/td-docs/build/index.js"]
    },
    "atlassian-jira": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-jira"],
      "env": {
        "ATLASSIAN_SITE_NAME": "talkdesk",
        "ATLASSIAN_USER_EMAIL": "li.jiang@talkdesk.com",
        "ATLASSIAN_API_TOKEN": "$JIRA_API_TOKEN"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "notebooklm-mcp": {
      "command": "/Users/cloud/.local/bin/notebooklm-mcp"
    }
  },
  "inputs": []
}
