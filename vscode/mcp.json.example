{
  "servers": {
    "notebooklm-mcp": {
      "command": "/Users/cloud/.local/bin/notebooklm-mcp"
    },
    "anythingllm": {
      "command": "npx",
      "args": ["-y", "anythingllm-mcp-server"],
      "env": {
        "ANYTHINGLLM_API_KEY": "${ANYTHINGLLM_API_KEY}",
        "ANYTHINGLLM_BASE_URL": "http://localhost:3001"
      }
    },
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "https://talkdesk.atlassian.net",
        "JIRA_USERNAME": "li.jiang@talkdesk.com",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "https://talkdesk.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "li.jiang@talkdesk.com",
        "CONFLUENCE_API_TOKEN": "${JIRA_API_TOKEN}"
      }
    },
    "Figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http"
    }
  },
  "inputs": []
}
