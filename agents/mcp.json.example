{
  "services": {
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "https://talkdesk.atlassian.net",
        "JIRA_USERNAME": "${env:ATLASSIAN_USER_EMAIL}",
        "JIRA_API_TOKEN": "${env:ATLASSIAN_API_TOKEN}",
        "CONFLUENCE_URL": "https://talkdesk.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "${env:ATLASSIAN_USER_EMAIL}",
        "CONFLUENCE_API_TOKEN": "${env:ATLASSIAN_API_TOKEN}"
      },
      "autoStart": false
    },
    "talkdesk-developer-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "--registry",
        "https://hub.talkdeskapp.com:8443/repository/talkdesk-npm",
        "--prefer-offline",
        "@talkdesk/developer-mcp@latest"
      ],
      "autoStart": false
    },
    "google-workspace": {
      "command": "uvx",
      "args": ["workspace-mcp"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${env:GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${env:GOOGLE_OAUTH_CLIENT_SECRET}"
      },
      "autoStart": false
    }
  },
  "mcpServices": {
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "https://talkdesk.atlassian.net",
        "JIRA_USERNAME": "${ATLASSIAN_USER_EMAIL}",
        "JIRA_API_TOKEN": "${ATLASSIAN_API_TOKEN}",
        "CONFLUENCE_URL": "https://talkdesk.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "${ATLASSIAN_USER_EMAIL}",
        "CONFLUENCE_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      },
      "autoStart": false
    },
    "talkdesk-developer-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "--registry",
        "https://hub.talkdeskapp.com:8443/repository/talkdesk-npm",
        "--prefer-offline",
        "@talkdesk/developer-mcp@latest"
      ],
      "autoStart": false
    },
    "google-workspace": {
      "command": "uvx",
      "args": ["workspace-mcp"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}"
      },
      "autoStart": false
    }
  }
}
