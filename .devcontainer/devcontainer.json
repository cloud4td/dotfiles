{
  "name": "Dev Container",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  
  // Mount dotfiles from host
  "mounts": [
    "source=${localEnv:HOME}/work/talkdesk/code/dotfiles,target=/home/vscode/dotfiles,type=bind,consistency=cached"
  ],
  
  // Command to run after container creation
  "postCreateCommand": "bash /home/vscode/dotfiles/scripts/install.sh",
  
  // Pass sensitive information from GitHub Secrets or environment variables
  "remoteEnv": {
    "COPILOT_MCP_FIGMA_API_TOKEN": "${localEnv:COPILOT_MCP_FIGMA_API_TOKEN}",
    "SNYK_TOKEN": "${localEnv:SNYK_TOKEN}",
    "FEDRAMP_SAR_CREDENTIAL_BASE64": "${localEnv:FEDRAMP_SAR_CREDENTIAL_BASE64}",
    "SONARQUBE_TOKEN": "${localEnv:SONARQUBE_TOKEN}",
    "BUNDLE_GITHUB__COM": "${localEnv:BUNDLE_GITHUB__COM}",
    "HOMEBREW_GITHUB_API_TOKEN": "${localEnv:HOMEBREW_GITHUB_API_TOKEN}",
    "COM_TD_WFM_DIALOGFLOW_CREDENTIALS": "${localEnv:COM_TD_WFM_DIALOGFLOW_CREDENTIALS}"
  },
  
  // Custom features
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true
    }
  }
}
